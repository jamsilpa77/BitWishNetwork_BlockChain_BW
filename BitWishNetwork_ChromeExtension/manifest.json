{
  "manifest_version": 3,
  "name": "BitWish Network Extension",
  "version": "1.0.0",
  "description": "BitWish Network Real-time Mining Dashboard, Attendance & Mnemonic Booster",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://bitwishnetwork.com/*",
    "*://www.bitwishnetwork.com/*",
    "http://localhost:5001/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://bitwishnetwork.com/*", "*://www.bitwishnetwork.com/*", "*://localhost/*", "http://localhost:5001/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
