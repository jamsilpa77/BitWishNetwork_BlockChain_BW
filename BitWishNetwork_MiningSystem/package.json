  "main": "server.js",
  "scripts": {
    "start": "webpack serve --config webpack.config.js --mode development",
    "build": "webpack --config webpack.config.js --mode production",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "server": "ts-node --project server/tsconfig.json server/index.ts",
    "dev:server": "nodemon --watch server --exec ts-node --project server/tsconfig.json server/index.ts",
    "backend": "set PORT=5001 && nodemon --watch server --exec ts-node --project server/tsconfig.json server/index.ts",
    "frontend": "webpack serve --config webpack.config.js --mode development",
    "dev": "concurrently \"npm run frontend\" \"npm run backend\"",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "keywords": [
    "bitcoin",
    "mining",
    "blockchain",
    "cryptocurrency",
    "bitwish",
    "bw",
    "point",
    "bonus"
