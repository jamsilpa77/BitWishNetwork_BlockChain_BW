server {
    listen 80;
    server_name bitwishnetwork.com 141.164.40.101;
    client_max_body_size 30M;
    return 301 https://bitwishnetwork.com$request_uri;
}

server {
    listen 443 ssl;
    server_name bitwishnetwork.com;
    client_max_body_size 30M;

    ssl_certificate /etc/letsencrypt/live/bitwishnetwork.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/bitwishnetwork.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    root /var/www/html;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        proxy_pass http://localhost:5001/api/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
