# BitWishNetwork BW 포인트 채굴 시스템 환경 변수
# 현재 토큰 이코노미는 완벽한 가상 이코노미입니다.
# 추후 KYC 시스템 구현과 블록체인 연결 지갑까지 완성하면 
# KYC 승인 후 실제 BW 토큰이 마이그레이션 되는 방식입니다.

# 서버 설정
NODE_ENV=development
PORT=3000
HOST=localhost

# 데이터베이스 설정
MONGODB_URI=mongodb://localhost:27017/bitwish_mining_system
MONGODB_DB_NAME=bitwish_mining_system

# 보안 설정
JWT_SECRET=bitwish_network_jwt_secret_key_2024
BCRYPT_ROUNDS=12

# 마이닝 시스템 설정
DEFAULT_MINING_RATE=0.25
DAILY_MAX_REWARD=6.0
MONTHLY_REWARD=180
YEARLY_REWARD=2190

# 보너스 설정
ATTENDANCE_BONUS_RATE=0.05
REFERRAL_BONUS_RATE=0.02
REFERRAL_REWARD_AMOUNT=1
PARTNER_BONUS_RATE=1.25

# 블록체인 설정
BLOCKCHAIN_NETWORK=mainnet
BLOCKCHAIN_RPC_URL=http://localhost:8545
BLOCKCHAIN_CHAIN_ID=1

# 언어 설정
DEFAULT_LANGUAGE=ko
SUPPORTED_LANGUAGES=ko,en,ja,zh

# 자동 새로고침 설정
AUTO_REFRESH_INTERVAL=30000
PAGE_REFRESH_INTERVAL=60000
